---
import "../assets/styles/style.scss";

/**
 * Layout racine minimal du sandbox BrandOS.
 *
 * Ce layout n'inclut PAS de Header/Footer pour rester utilisable
 * avant que ces composants soient copiés localement depuis SiteA11Y.
 *
 * Quand Header/Footer seront copiés via `pnpm sync-from-prod`,
 * créer un `FullLayout.astro` qui les wrappe par-dessus celui-ci.
 */
interface Props {
	title: string;
	description?: string;
	lang?: string;
}

const { title, description, lang = "fr" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
	</head>
	<body>
		<slot />
	</body>
</html>
